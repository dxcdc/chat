# ==============================================================================
# CDC Chat - Modelo de Configuração de Ambiente (.env.example)
# ==============================================================================
# Instruções:
# 1. Copie este arquivo para .env: cp .env.example .env
# 2. Preencha os valores reais de acordo com o ambiente (desenvolvimento/produção).
# 3. NUNCA envie o arquivo .env preenchido para o repositório Git.
# ==============================================================================

# Ambiente e Execução
APP_ENV=development
APP_PORT=8065
APP_URL=http://localhost:8065
MATTERMOST_IMAGE_TAG=9.11

# Banco de Dados (PostgreSQL)
DB_HOST=db
DB_PORT=5432
DB_NAME=mattermost
DB_USER=mmuser
DB_PASS=<DB_PASSWORD>

# Configuração de E-mail (Notificações do Mattermost)
SMTP_HOST=<SERVIDOR_SMTP>
SMTP_PORT=587
SMTP_USER=<USUARIO_SMTP>
SMTP_PASSWORD=<SMTP_PASSWORD>
SMTP_ENCRYPTION=starttls
SMTP_FROM_ADDRESS=<EMAIL_REMETENTE>
SMTP_FROM_NAME=<NOME_DO_PROJETO>

# API de Alertas do Mattermost (Envio de alertas operacionais/backups)
# Nota: Para o próprio chat, estes alertas podem ser direcionados a um canal interno de logs
MATTERMOST_ENABLED=false
MATTERMOST_WEBHOOK_URL=<MATTERMOST_WEBHOOK_URL>
MATTERMOST_CHANNEL=<MATTERMOST_CHANNEL>
MATTERMOST_USERNAME=ChatBot
MATTERMOST_ICON_URL=<URL_PUBLICA_DO_ICONE>
MATTERMOST_TIMEOUT_SECONDS=10

# Rotinas de Backup Automatizado
BACKUP_PROJECT_NAME=cdc-chat
BACKUP_ENVIRONMENT=production
BACKUP_DESTINATION=/home/vier/backups/chat
BACKUP_RETENTION_DAYS=30
GPG_PASSPHRASE_FILE=/home/vier/.gpg_passphrase
